# ──────────────────────────────────────────────────
# Mythos CLI — Environment Configuration
# ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
#
#   cp .env.example .env
#

# Disable upstream experimental beta features from Anthropic.
# Since Mythos is a fork, you likely don't want experimental
# flags from Claude Code activating unexpectedly.
#   1 = disabled (recommended for Mythos)
#   0 = enabled
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# Skip official installation channel checks (npm, brew, etc.).
# Required for source builds via Bun — without this, the CLI
# may show warnings or refuse to start.
#   1 = skip checks (recommended for dev/source builds)
#   0 = run checks
DISABLE_INSTALLATION_CHECKS=1
